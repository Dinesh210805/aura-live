logs/
data/failure_screenshots/
data/screenshots/

# Android source (not needed in backend container)
UI/

# Code reference helpers (not production code)
code helpers/

# Git history
.git/
.gitignore
.github/

# Documentation
*.md
docs/

# Editor / OS artifacts
.DS_Store
.idea/
