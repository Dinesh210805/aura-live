# AURA Configuration - Copy this file to .env and fill in your keys
# cp .env.example .env

# =========================================================
# Required API Keys
# =========================================================
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: LangSmith observability
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=aura-agent-visualization

# =========================================================
# Server Settings
# =========================================================
HOST=0.0.0.0
PORT=8000
RELOAD=False
LOG_LEVEL=INFO

# =========================================================
# Agent Configuration
# =========================================================
USE_UNIVERSAL_AGENT=true

# =========================================================
# Perception Configuration
# =========================================================
DEFAULT_PERCEPTION_MODALITY=hybrid
# FAST_PERCEPTION_APPS=com.android.settings,com.android.contacts

# =========================================================
# LLM / VLM Model Selection
# =========================================================
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.1-8b-instant
LLM_FALLBACK_MODEL=llama-3.3-70b-versatile
COMMANDER_MODEL=llama-3.3-70b-versatile

DEFAULT_VLM_PROVIDER=groq
DEFAULT_VLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VLM_SECONDARY_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
FALLBACK_VLM_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
FALLBACK_VLM_PROVIDER=openrouter

PLANNING_PROVIDER=groq
PLANNING_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
PLANNING_FALLBACK_MODEL=gemini-2.5-flash
PLANNING_FALLBACK_PROVIDER=gemini

SAFETY_MODEL=meta-llama/llama-prompt-guard-2-86m
CREWAI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# =========================================================
# Speech-to-Text / Text-to-Speech
# =========================================================
DEFAULT_STT_PROVIDER=groq
DEFAULT_STT_MODEL=whisper-large-v3-turbo

# Optional: pin a language code for STT (leave empty for auto-detect)
# Supported: en, ta, hi, es, fr, de, ja, ko, zh, ar, ru, ...
# DEFAULT_STT_LANGUAGE=

DEFAULT_TTS_PROVIDER=android
DEFAULT_TTS_MODEL=en-US-AriaNeural

# Android-native TTS (recommended for production — eliminates server-side audio synthesis,
# reduces latency from ~1.4s to ~200ms by delegating synthesis to the Android device).
# Set to false only when running without an Android client (e.g., standalone API testing).
ANDROID_TTS_ENABLED=true

# =========================================================
# Performance Enhancements
# =========================================================

# Perception Cache - reduces redundant screen captures
PERCEPTION_CACHE_ENABLED=true
PERCEPTION_CACHE_TTL=2.0
PERCEPTION_CACHE_MAX_ACTIONS=1

# Adaptive Delays - intelligent delays based on confidence
ADAPTIVE_DELAYS_ENABLED=true
ADAPTIVE_DELAYS_MIN_SAMPLES=5

# Agent Monitor - real-time performance tracking
AGENT_MONITOR_ENABLED=true
AGENT_MONITOR_HISTORY_SIZE=100
AGENT_MONITOR_ALERT_SUCCESS_RATE=0.5
AGENT_MONITOR_ALERT_LOOP_RATE=0.3

# VLM Proactive Usage
VLM_PROACTIVE_ENABLED=true
VLM_CACHE_TTL=5.0

# LangGraph execution limits (FIX-001, FIX-015)
# GRAPH_RECURSION_LIMIT=100
# GRAPH_TIMEOUT_SECONDS=120.0

# Perception tuning (FIX-005)
# UI_TREE_MAX_RETRIES=1
# UI_TREE_RETRY_DELAY_SECONDS=0.3

# Reactive step history window (FIX-013)
# STEP_HISTORY_WINDOW=6

# =========================================================
# Device API & Security
# =========================================================
# Environment: "development" or "production"
# In production: debug endpoints are disabled, OpenAPI docs are hidden,
# wildcard CORS is overridden, and require_api_key defaults to true.
ENVIRONMENT=development

REQUIRE_API_KEY=true
DEVICE_API_KEY=change-me-before-deploying

# CORS origins (comma-separated). Set explicit origins for production.
# CORS_ORIGINS=https://your-app.example.com

# Trusted hosts for TrustedHostMiddleware. Set your Cloud Run domain in production.
# ALLOWED_HOSTS=your-service.run.app,localhost

# =========================================================
# Google Cloud Platform (required for Gemini Live Challenge)
# =========================================================
# Get GOOGLE_API_KEY from https://aistudio.google.com/app/apikey
# GEMINI_API_KEY above is also accepted for backward-compat.
GOOGLE_API_KEY=your_google_api_key_from_aistudio
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# Cloud Storage execution logs (set GCS_LOGS_ENABLED=true after bucket created)
GCS_LOGS_BUCKET=aura-execution-logs
GCS_LOGS_ENABLED=false

# Gemini Live bidirectional audio+vision streaming (Phase 2 - enable after testing)
GEMINI_LIVE_ENABLED=false

# AuraQueryEngine — streaming entry point with TaskUpdate events (Phase 3)
# Set to true to route all tasks through AuraQueryEngine instead of direct app.ainvoke()
AURA_QUERY_ENGINE_ENABLED=true
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Force transcript language/script for Gemini Live (set auto for auto-detect)
GEMINI_LIVE_TRANSCRIPTION_LANGUAGE=en-US

# Vertex AI routing (optional second GCP service - improves judging score)
USE_VERTEX_AI=false

# ADK app name (used by InMemorySessionService)
ADK_APP_NAME=AURA

# =========================================================
# MCP Server (Model Context Protocol)
# =========================================================
# Run separately: python aura_mcp_server.py
# Prerequisite: AURA FastAPI server must already be running (python main.py)
MCP_ENABLED=true
MCP_SERVER_NAME=aura
